{
	"name": "@grandplan/auth",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./types": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"typescript": "catalog:",
		"@grandplan/config": "workspace:*"
	},
	"dependencies": {
		"better-auth": "catalog:",
		"@polar-sh/better-auth": "catalog:",
		"@polar-sh/sdk": "^0.34.16",
		"dotenv": "catalog:",
		"zod": "catalog:",
		"@grandplan/env": "workspace:*",
		"@grandplan/db": "workspace:*"
	}
}
