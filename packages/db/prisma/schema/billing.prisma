// ============================================
// BILLING - Subscriptions & Payments
// ============================================

// Subscription plans (defined by platform admins)
model Plan {
  id                String          @id @default(cuid())
  name              String          @unique
  description       String?

  // Pricing
  priceMonthly      Decimal?        @db.Decimal(10, 2)
  priceYearly       Decimal?        @db.Decimal(10, 2)
  currency          String          @default("USD")

  // Limits
  maxUsers          Int?            // null = unlimited
  maxTeams          Int?
  maxProjects       Int?
  maxStorageGB      Int?
  maxAIRequestsPerMonth Int?

  // Features included (JSON for flexibility)
  features          Json            @default("{}") // { "feature1": true, "feature2": false, ... }

  // External IDs for payment providers
  polarProductId        String?
  stripePriceIdMonthly  String?
  stripePriceIdYearly   String?

  isActive          Boolean         @default(true)
  isEnterprise      Boolean         @default(false)  // Enterprise plans have custom pricing
  isFree            Boolean         @default(false)  // Free tier

  trialDays         Int             @default(14)
  displayOrder      Int             @default(0)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  subscriptions     Subscription[]

  @@index([isActive])
  @@index([displayOrder])
  @@map("plan")
}

// Organization subscriptions
model Subscription {
  id                String              @id @default(cuid())
  organizationId    String              @unique
  planId            String

  status            SubscriptionStatus  @default(TRIALING)
  billingCycle      BillingCycle        @default(MONTHLY)

  // Payment provider info
  paymentProvider   PaymentProvider?
  externalId        String?             // Polar/Stripe subscription ID
  customerId        String?             // Polar/Stripe customer ID

  // Dates
  trialEndsAt         DateTime?
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelledAt         DateTime?
  cancelAtPeriodEnd   Boolean           @default(false)

  // Usage tracking
  usedSeats         Int                 @default(0)
  usedStorageGB     Decimal             @default(0) @db.Decimal(10, 2)
  usedAIRequests    Int                 @default(0)

  // Custom overrides for enterprise
  customLimits      Json?               // Override plan limits

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan              Plan                @relation(fields: [planId], references: [id])
  invoices          Invoice[]
  usageRecords      UsageRecord[]

  @@index([organizationId])
  @@index([status])
  @@index([externalId])
  @@index([currentPeriodEnd])
  @@map("subscription")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
  INCOMPLETE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentProvider {
  POLAR
  STRIPE
}

// Invoice tracking
model Invoice {
  id                String          @id @default(cuid())
  subscriptionId    String

  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("USD")
  status            InvoiceStatus

  externalId        String?         // Polar/Stripe invoice ID
  invoiceUrl        String?
  pdfUrl            String?
  hostedInvoiceUrl  String?

  periodStart       DateTime
  periodEnd         DateTime
  dueDate           DateTime?
  paidAt            DateTime?

  createdAt         DateTime        @default(now())

  subscription      Subscription    @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([externalId])
  @@map("invoice")
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

// Usage tracking for metered billing
model UsageRecord {
  id                String          @id @default(cuid())
  subscriptionId    String

  metric            String          // "api_calls", "storage_gb", "seats", "ai_requests", etc.
  quantity          Decimal         @db.Decimal(10, 4)

  recordedAt        DateTime        @default(now())
  periodStart       DateTime
  periodEnd         DateTime

  metadata          Json?           // Additional context

  subscription      Subscription    @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, metric])
  @@index([periodStart, periodEnd])
  @@index([recordedAt])
  @@map("usage_record")
}
