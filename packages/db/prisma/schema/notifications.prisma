// ============================================
// NOTIFICATIONS - Notification System
// ============================================

model Notification {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  type          NotificationType
  title         String
  body          String?
  data          Json?            // Flexible payload (links, context, action data)

  read          Boolean          @default(false)
  readAt        DateTime?
  archivedAt    DateTime?

  createdAt     DateTime         @default(now())

  // For grouping/deduplication
  groupKey      String?

  // Context
  actorId       String?          // Who triggered this notification
  actor         User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  resourceType  String?          // "task", "project", "comment", etc.
  resourceId    String?
  organizationId String?

  // Delivery tracking
  emailSentAt   DateTime?
  pushSentAt    DateTime?
  slackSentAt   DateTime?

  @@index([userId, read, createdAt])
  @@index([userId, archivedAt])
  @@index([userId, groupKey])
  @@index([resourceType, resourceId])
  @@index([organizationId])
  // Composite index for filtering unread by type
  @@index([userId, read, type])
  // Index for notification listing by type
  @@index([userId, type, createdAt])
  @@map("notification")
}

enum NotificationType {
  // Task notifications
  TASK_ASSIGNED
  TASK_UNASSIGNED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_DUE_SOON
  TASK_OVERDUE
  TASK_BLOCKED
  TASK_UNBLOCKED

  // Comment/Mention
  COMMENT_ADDED
  COMMENT_REPLY
  MENTION

  // Project/Workspace
  PROJECT_CREATED
  PROJECT_ARCHIVED
  WORKSPACE_INVITE

  // Team/Organization
  TEAM_INVITE
  TEAM_MEMBER_JOINED
  TEAM_MEMBER_LEFT
  ORG_INVITE
  ORG_MEMBER_JOINED

  // AI
  AI_DECOMPOSITION_READY
  AI_SUGGESTION_AVAILABLE

  // Integration
  INTEGRATION_CONNECTED
  INTEGRATION_DISCONNECTED
  INTEGRATION_SYNC_COMPLETE
  INTEGRATION_SYNC_FAILED

  // Billing
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_RENEWED
  SUBSCRIPTION_CANCELLED
  PAYMENT_FAILED
  TRIAL_ENDING

  // System
  SYSTEM_ANNOUNCEMENT
  SYSTEM_MAINTENANCE
}

// User notification preferences
model NotificationPreference {
  id               String          @id @default(cuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Global channel preferences
  emailEnabled     Boolean         @default(true)
  pushEnabled      Boolean         @default(true)
  inAppEnabled     Boolean         @default(true)
  slackEnabled     Boolean         @default(false)

  // Digest settings
  digestEnabled    Boolean         @default(false)
  digestFrequency  DigestFrequency @default(DAILY)
  digestTime       String?         // "09:00" in user's timezone

  // Per-type settings (JSON for flexibility)
  // Format: { "TASK_ASSIGNED": { "email": true, "push": true }, ... }
  typeSettings     Json            @default("{}")

  // Quiet hours
  quietHoursEnabled Boolean        @default(false)
  quietHoursStart  String?         // "22:00"
  quietHoursEnd    String?         // "08:00"
  timezone         String          @default("UTC")

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("notification_preference")
}

enum DigestFrequency {
  HOURLY
  DAILY
  WEEKLY
}

// Push notification subscriptions (Web Push)
model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint     String   @unique
  p256dh       String   // Public key
  auth         String   // Auth secret

  userAgent    String?
  deviceName   String?

  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
  @@map("push_subscription")
}

// Digest queue for batched notifications
model DigestQueue {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  frequency    DigestFrequency
  notifications Json           // Array of notification data to include

  scheduledFor DateTime
  processedAt  DateTime?

  createdAt    DateTime        @default(now())

  @@index([scheduledFor, processedAt])
  @@index([userId])
  @@map("digest_queue")
}
