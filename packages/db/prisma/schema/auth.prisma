// ============================================
// AUTH - User Authentication & Core User Model
// ============================================

model User {
  id            String  @id
  name          String
  email         String
  emailVerified Boolean @default(false)
  image         String?

  // User status
  status UserStatus @default(ACTIVE)

  // Track current active organization (for multi-org users)
  activeOrganizationId String?

  // User preferences/localization
  timezone String? // IANA timezone (e.g., "America/New_York")
  locale   String? // Locale code (e.g., "en-US")

  // Security tracking
  lastLoginAt DateTime?
  lastLoginIp String?

  // Soft delete for GDPR compliance
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth relations
  sessions Session[]
  accounts Account[]

  // Organization & Team relations
  organizationMemberships OrganizationMember[]
  invitedMembers          OrganizationMember[]     @relation("InvitedMembers")
  sentInvitations         OrganizationInvitation[] @relation("SentInvitations")

  // Workspace relations
  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]

  // Task relations
  createdTasks        TaskNode[]       @relation("TaskCreator")
  assignedTasks       TaskNode[]       @relation("TaskAssignee")
  createdDependencies TaskDependency[] @relation("DependencyCreator")
  taskHistory         TaskHistory[]    @relation("TaskHistoryActor")
  taskComments        TaskComment[]    @relation("CommentAuthor")
  aiDecisionRequests  TaskAIDecision[] @relation("AIDecisionRequester")

  // Notification relations
  notifications          Notification[]          @relation("UserNotifications")
  triggeredNotifications Notification[]          @relation("NotificationActor")
  notificationPreference NotificationPreference?
  pushSubscriptions      PushSubscription[]
  digestQueue            DigestQueue[]

  // Audit relations
  auditLogs AuditLog[] @relation("AuditLogUser")

  // Platform admin
  platformAdmin PlatformAdmin?

  // Integration relations
  integrationConnections IntegrationConnection[]
  calendarEvents         CalendarEvent[]

  // Attachment relations
  uploadedAttachments TaskAttachment[]

  // Onboarding & GDPR
  onboardingProgress OnboardingProgress?
  dataExportRequests DataExportRequest[]

  @@unique([email])
  @@index([status])
  @@index([activeOrganizationId])
  @@index([deletedAt])
  @@index([lastLoginAt])
  @@map("user")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DELETED
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@index([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
  @@map("verification")
}
