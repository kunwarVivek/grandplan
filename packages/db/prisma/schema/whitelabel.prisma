// ============================================
// WHITE-LABEL - Customization & Feature Flags
// ============================================

// Global feature flag definitions
model FeatureFlag {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?

  defaultEnabled Boolean @default(false)
  isPublic       Boolean @default(false) // Show in UI for org admins

  // Which plans include this feature by default
  includedInPlans String[] // Plan names array

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublic])
  @@map("feature_flag")
}

// Organization-specific feature flag overrides
model OrganizationFeatureFlag {
  id             String @id @default(cuid())
  organizationId String
  featureKey     String

  enabled Boolean @default(false)
  config  Json? // Feature-specific configuration

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, featureKey])
  @@index([organizationId])
  @@index([featureKey])
  @@map("organization_feature_flag")
}

// Custom email templates per organization
model EmailTemplate {
  id             String @id @default(cuid())
  organizationId String

  templateType EmailTemplateType
  subject      String
  bodyHtml     String            @db.Text
  bodyText     String?           @db.Text

  variables Json? // Available template variables documentation

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, templateType])
  @@index([organizationId])
  @@index([isActive])
  @@map("email_template")
}

enum EmailTemplateType {
  WELCOME
  INVITATION
  PASSWORD_RESET
  SUBSCRIPTION_CONFIRMED
  SUBSCRIPTION_CANCELLED
  SUBSCRIPTION_RENEWED
  PAYMENT_FAILED
  INVOICE
  TEAM_ADDED
  TASK_ASSIGNED
  TASK_DUE_REMINDER
  MENTION
  WEEKLY_DIGEST
}

// Custom domain configuration
model CustomDomain {
  id             String @id @default(cuid())
  organizationId String @unique

  domain            String    @unique
  verificationToken String    @unique
  verifiedAt        DateTime?

  sslStatus    SSLStatus @default(PENDING)
  sslExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domain])
  @@index([verifiedAt])
  @@map("custom_domain")
}

enum SSLStatus {
  PENDING
  PROVISIONING
  ACTIVE
  FAILED
  EXPIRED
}
