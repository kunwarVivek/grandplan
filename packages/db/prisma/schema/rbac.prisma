// ============================================
// RBAC - Role-Based Access Control
// ============================================

// Role definitions
model Role {
  id              String            @id @default(cuid())
  name            String
  description     String?

  // Scope: PLATFORM = admin roles, ORGANIZATION = org-specific, TEAM = team-specific
  scope           RoleScope         @default(ORGANIZATION)

  // If null, it's a system role; otherwise org-specific custom role
  organizationId  String?

  isSystem        Boolean           @default(false)  // System roles cannot be modified/deleted

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  permissions     RolePermission[]
  members         OrganizationMember[]
  teamMembers     TeamMember[]      @relation("TeamRole")
  invitations     OrganizationInvitation[]

  @@unique([name, organizationId, scope])
  @@index([organizationId])
  @@index([scope])
  @@index([isSystem])
  @@map("role")
}

enum RoleScope {
  PLATFORM      // Platform-wide admin roles
  ORGANIZATION  // Organization-level roles
  TEAM          // Team-specific roles
}

// Permission definitions
model Permission {
  id              String            @id @default(cuid())
  code            String            @unique  // e.g., "users:read", "billing:manage"
  name            String
  description     String?
  category        String            // Grouping: "users", "billing", "teams", etc.

  rolePermissions RolePermission[]

  @@index([category])
  @@map("permission")
}

// Role-Permission junction table
model RolePermission {
  id              String      @id @default(cuid())
  roleId          String
  permissionId    String

  createdAt       DateTime    @default(now())

  role            Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission      Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permission")
}
