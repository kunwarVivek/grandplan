// ============================================
// AUDIT - Comprehensive Audit Logging
// ============================================

// Organization-scoped audit logs
model AuditLog {
  id              String          @id @default(cuid())

  // Who
  userId          String?         // null for system actions
  organizationId  String?         // null for platform-level actions

  // What
  action          String          // "user.created", "subscription.updated", etc.
  resourceType    String          // "user", "team", "subscription", etc.
  resourceId      String?

  // Details
  description     String?
  metadata        Json?           // Additional context
  previousState   Json?           // State before change
  newState        Json?           // State after change

  // Where
  ipAddress       String?
  userAgent       String?

  // When
  createdAt       DateTime        @default(now())

  // Relations
  user            User?           @relation("AuditLogUser", fields: [userId], references: [id], onDelete: SetNull)
  organization    Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}

// System-wide platform logs (for platform admins only)
model PlatformLog {
  id              String          @id @default(cuid())

  level           LogLevel
  category        String          // "auth", "billing", "system", "integration", etc.
  message         String
  metadata        Json?

  // Request context
  requestId       String?
  userId          String?
  organizationId  String?

  // Error details
  errorCode       String?
  errorStack      String?         @db.Text

  createdAt       DateTime        @default(now())

  @@index([level])
  @@index([category])
  @@index([createdAt])
  @@index([requestId])
  @@index([errorCode])
  @@map("platform_log")
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  CRITICAL
}

// Security events for compliance
model SecurityEvent {
  id              String          @id @default(cuid())

  eventType       SecurityEventType
  severity        SecuritySeverity

  userId          String?
  organizationId  String?

  description     String
  metadata        Json?

  ipAddress       String?
  userAgent       String?
  location        String?         // Geo-location if available

  resolved        Boolean         @default(false)
  resolvedAt      DateTime?
  resolvedById    String?
  resolutionNotes String?

  createdAt       DateTime        @default(now())

  @@index([eventType])
  @@index([severity])
  @@index([userId])
  @@index([organizationId])
  @@index([resolved])
  @@index([createdAt])
  @@map("security_event")
}

enum SecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGIN_SUSPICIOUS
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  MFA_ENABLED
  MFA_DISABLED
  SESSION_REVOKED
  API_KEY_CREATED
  API_KEY_REVOKED
  PERMISSION_ESCALATION
  DATA_EXPORT
  BULK_DELETE
  INTEGRATION_CONNECTED
  INTEGRATION_DISCONNECTED
}

enum SecuritySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
