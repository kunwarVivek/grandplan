{
	"name": "grandplan",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"check": "biome check --write .",
		"dev": "turbo dev",
		"build": "turbo build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @grandplan/db db:push",
		"db:studio": "turbo -F @grandplan/db db:studio",
		"db:generate": "turbo -F @grandplan/db db:generate",
		"db:migrate": "turbo -F @grandplan/db db:migrate",
		"db:start": "turbo -F @grandplan/db db:start",
		"db:watch": "turbo -F @grandplan/db db:watch",
		"db:stop": "turbo -F @grandplan/db db:stop",
		"db:down": "turbo -F @grandplan/db db:down"
	},
	"dependencies": {
		"@grandplan/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@grandplan/config": "workspace:*",
		"@playwright/test": "^1.58.2",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "^3.1.0",
		"playwright": "^1.58.2",
		"turbo": "^2.6.3",
		"typescript": "catalog:",
		"vitest": "^3.1.0"
	},
	"packageManager": "pnpm@10.20.0"
}
