# ===========================================
# GrandPlan Worker Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# Railway will automatically inject DATABASE_URL and REDIS_URL

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://postgres:password@localhost:5432/grandplan
# For Railway: ${{Postgres.DATABASE_URL}}

# Redis (Railway provides this automatically)
REDIS_URL=redis://localhost:6379
# For Railway: ${{Redis.REDIS_URL}}

# AI Providers (for AI decomposition worker)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Email (SendGrid) - for email worker
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=notifications@grandplan.app

# Push Notifications (VAPID keys) - for notification worker
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Encryption (for secure data handling)
ENCRYPTION_KEY=your-64-character-hex-string-for-encryption-key

# Slack Integration (for integration sync worker)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Jira Integration
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Asana Integration
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# Linear Integration
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Notion Integration
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft (Teams, Outlook Calendar)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
