# ===========================================
# GrandPlan Web Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server URL - API endpoint for the backend
VITE_SERVER_URL=http://localhost:3000
# For Railway: https://your-server-app.up.railway.app

# Optional: Analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Optional: Sentry for error tracking
VITE_SENTRY_DSN=
