# ===========================================
# GrandPlan Server Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# Railway will automatically inject DATABASE_URL and REDIS_URL

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://postgres:password@localhost:5432/grandplan
# For Railway: ${{Postgres.DATABASE_URL}}

# Redis (Railway provides this automatically)
REDIS_URL=redis://localhost:6379
# For Railway: ${{Redis.REDIS_URL}}

# Server Port (Railway sets this automatically)
PORT=3000

# Authentication
BETTER_AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
# For Railway: ${{RAILWAY_PUBLIC_DOMAIN}} with https://

# CORS
CORS_ORIGIN=http://localhost:3001
# For Railway: https://your-web-app.up.railway.app

# App URL (for emails, notifications)
APP_URL=http://localhost:3001
# For Railway: https://your-web-app.up.railway.app

# AI Providers
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Polar (existing payment provider)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SUCCESS_URL=http://localhost:3001/billing/success

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Email (SendGrid)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=notifications@grandplan.app

# Push Notifications (VAPID keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Encryption (32 bytes hex for AES-256)
ENCRYPTION_KEY=your-64-character-hex-string-for-encryption-key

# Slack Integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Jira Integration
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Asana Integration
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# Linear Integration
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Notion Integration
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft (Teams, Outlook Calendar)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
