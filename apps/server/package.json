{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.js",
		"docs:validate": "npx @apidevtools/swagger-cli validate openapi.yaml",
		"docs:serve": "echo 'API docs available at http://localhost:3001/api/docs when server is running'"
	},
	"dependencies": {
		"@grandplan/ai": "workspace:*",
		"@grandplan/audit": "workspace:*",
		"@grandplan/auth": "workspace:*",
		"@grandplan/core": "workspace:*",
		"@grandplan/db": "workspace:*",
		"@grandplan/env": "workspace:*",
		"@grandplan/events": "workspace:*",
		"@grandplan/integrations": "workspace:*",
		"@grandplan/notifications": "workspace:*",
		"@grandplan/payments": "workspace:*",
		"@grandplan/queue": "workspace:*",
		"@grandplan/rbac": "workspace:*",
		"@grandplan/realtime": "workspace:*",
		"@grandplan/tenant": "workspace:*",
		"better-auth": "catalog:",
		"cors": "^2.8.5",
		"dotenv": "catalog:",
		"express": "^5.1.0",
		"ioredis": "^5.4.2",
		"multer": "^2.1.1",
		"swagger-ui-express": "^5.0.1",
		"yamljs": "^0.3.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@grandplan/config": "workspace:*",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.1",
		"@types/multer": "^1.4.13",
		"@types/node": "catalog:",
		"@types/swagger-ui-express": "^4.1.8",
		"@types/yamljs": "^0.2.34",
		"tsdown": "^0.16.5",
		"tsx": "^4.19.2",
		"typescript": "catalog:"
	}
}
